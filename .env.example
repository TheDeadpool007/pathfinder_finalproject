# API Keys (Get free keys from the respective platforms)

# OpenTripMap API Key
# Sign up: https://opentripmap.io/product
OPENTRIPMAP_API_KEY=your_opentripmap_key_here

# OpenRouteService API Key  
# Sign up: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=your_openrouteservice_key_here

# Ollama Model (Optional - for LLM enhancement)
# Install Ollama from https://ollama.ai
# Then run: ollama pull qwen2.5:0.5b
OLLAMA_MODEL=qwen2.5:0.5b

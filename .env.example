# API Keys (all free tiers)

# Geoapify key (required)
# Used for geocoding, places search, and routing in current pipeline.
# Sign up: https://www.geoapify.com/get-started-with-maps-api
GEOAPIFY_API_KEY=your_geoapify_key_here

# Groq key (optional but recommended)
# Used for NL parsing and richer itinerary explanations.
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Groq model (optional)
GROQ_MODEL=llama-3.1-8b-instant

# Ollama model (optional local fallback)
# Install Ollama from https://ollama.ai
# Then run: ollama pull qwen2.5:0.5b
OLLAMA_MODEL=qwen2.5:0.5b
